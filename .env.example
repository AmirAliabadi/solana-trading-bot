# Your Solana Wallet Private Key (Base58 encoded string)
PRIVATE_KEY=your_base58_private_key_here

# The RPC URL to use for sending transactions (Mainnet Beta recommended, or your own Helius/QuickNode RPC)
RPC_URL=https://api.mainnet-beta.solana.com
# Choose your trading strategy: MEAN_REVERSION, ALWAYS_BUY, BOLLINGER_BANDS, TREND_FOLLOWING, SIMPLE_TREND
ACTIVE_STRATEGY=MEAN_REVERSION
# Jupiter Public API for quotes
JUPITER_API_URL=https://public.jupiterapi.com

# Amount of SOL to trade in each run (Default is 0.01)
TRADE_AMOUNT_SOL=0.01

# Whether to skip preflight checks when sending transactions
SKIP_PREFLIGHT=true

# How often the bot polls for market data (in milliseconds)
POLL_INTERVAL=60000

# Technical Analysis Strategy Thresholds
# Buy when RSI is below this value (Default: 40)
BUY_RSI_THRESHOLD=40
# Sell when RSI is above this value (Default: 60)
SELL_RSI_THRESHOLD=60

# Liquidity/Price Impact Guard (%)
# If a trade will cause more than this percentage of price impact, it will be blocked.
MAX_PRICE_IMPACT=0.1

# VWAP Strategy Configuration
# Enable/Disable the VWAP price filter (true/false)
USE_VWAP=false
# Offset percentage from the VWAP line (Default: 0.0)
VWAP_OFFSET_PERCENT=0.0

# MACD Strategy Configuration
# Enable/Disable the MACD histogram filter (true/false)
USE_MACD=true
# Standard periods: 12, 26, 9
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9

# Data Logging for Backtesting
# If true, the bot will save raw TA data to logs/backtest_data.csv
ENABLE_DATA_LOGGING=true

# Post-Swap Simulation Delay (ms) - How long to wait after a swap before resuming polling
POST_SWAP_DELAY_MS=5000

# Profit Threshold (%) - Minimum profit required to swap back to starting token
PROFIT_THRESHOLD_PERCENT=0.2

# Simple Trend Strategy Configuration
# Buy when price rises by this percentage from the local low (Default: 3.0)
SIMPLE_TREND_BUY_PCT=2.0
# Sell when price drops by this percentage from the local peak (Default: 4.0)
SIMPLE_TREND_SELL_PCT=3.0

# Discord Notifications
# Get your webhook URL from Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
